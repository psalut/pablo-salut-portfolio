---
import '../styles/global.css';
import backgroundImage from '../assets/images/back.png';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Tu Nombre | Frontend Developer',
  description = 'Portfolio personal de desarrollador frontend.',
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body class="text-white antialiased" style={`--page-bg-image: url(${backgroundImage.src});`}>
    <div class="page-background" aria-hidden="true">
      <div class="page-background__image"></div>
      <div class="page-background__glow page-background__glow--primary"></div>
      <div class="page-background__glow page-background__glow--secondary"></div>
      <div class="page-background__grid"></div>
      <div class="page-background__shade"></div>
    </div>
    <slot />
    <script is:inline>
      (() => {
        const root = document.documentElement;
        const homeSection = document.getElementById("home");

        if (!homeSection) {
          return;
        }

        let ticking = false;

        const updateBackgroundState = () => {
          const scrollY = window.scrollY;
          const heroHeight = Math.max(homeSection.offsetHeight, window.innerHeight * 0.9);
          const transitionDistance = Math.max(heroHeight * 0.7, 320);
          const progress = Math.min(scrollY / transitionDistance, 1);
          const eased = 1 - Math.pow(1 - progress, 3);

          root.style.setProperty("--bg-blur", `${(eased * 18).toFixed(2)}px`);
          root.style.setProperty("--bg-image-scale", `${(1 + eased * 0.04).toFixed(3)}`);
          root.style.setProperty("--bg-image-opacity", `${(1 - eased * 0.45).toFixed(3)}`);
          root.style.setProperty("--bg-shade-opacity", `${(0.18 + eased * 0.48).toFixed(3)}`);
          root.style.setProperty("--bg-grid-opacity", `${(0.08 - eased * 0.05).toFixed(3)}`);
          ticking = false;
        };

        const requestUpdate = () => {
          if (ticking) {
            return;
          }

          ticking = true;
          window.requestAnimationFrame(updateBackgroundState);
        };

        updateBackgroundState();
        window.addEventListener("scroll", requestUpdate, { passive: true });
        window.addEventListener("resize", requestUpdate);
      })();
    </script>
  </body>
</html>
