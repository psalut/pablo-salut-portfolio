---
import vetAndCookImage from '../../assets/images/vetandcook.webp';
import skillsTrackerImage from '../../assets/images/skillstracker.webp';
import portfolioImage from '../../assets/images/portfolio.webp';

const projects = [
  {
    number: '01',
    title: 'Vet&Cook',
    eyebrow: 'Frontend Product',
    description:
      'Plataforma con foco en experiencia visual, arquitectura de componentes y una interfaz responsive pensada para convertir una idea de producto en una experiencia clara.',
    stack: ['Angular', 'TypeScript', 'SCSS', 'UX/UI'],
    image: vetAndCookImage,
    liveUrl: 'https://www.vetandcook.com/home'
  },
  {
    number: '02',
    title: 'Skills Tracker',
    eyebrow: 'Full Stack App',
    description:
      'Aplicación pensada para seguimiento de skills con una base técnica más amplia: API, estructura modular y decisiones orientadas a escalabilidad dentro de un monorepo.',
    stack: ['Angular', 'NestJS', 'Nx', 'PostgreSQL'],
    image: skillsTrackerImage,
    liveUrl: 'https://skills-tracker-mu.vercel.app/',
    githubUrl: 'https://github.com/psalut/skills-tracker',
  },
  {
    number: '03',
    title: 'Portfolio Website',
    eyebrow: 'Personal Brand',
    description:
      'Este portfolio, creado para mostrar criterio visual, performance, estructura mantenible y una forma de construir interfaces con una dirección estética mas definida.',
    stack: ['Astro', 'React', 'Tailwind', 'Motion'],
    image: portfolioImage,
    liveUrl: 'https://example.com/portfolio',
    githubUrl: 'https://github.com/psalut/pablo-salut-portfolio',
  },
];
---

<section id="projects" class="relative section-spacing">
  <div class="section-container projects-shell">
    <div class="projects-rail" aria-hidden="true">
      <span class="projects-rail__node projects-rail__node--top"></span>
      <span class="projects-rail__line"></span>
    </div>

    <div class="space-y-10 md:space-y-14">
      <div class="flex items-start justify-between gap-8">
        <div class="space-y-4">
          <p class="text-sm uppercase tracking-[0.3em] text-slate-400">Projects</p>
          <h2 class="m-0 text-3xl font-semibold leading-none tracking-tight text-[#ff6b2d] md:text-5xl">
            Selected <span class="text-white">Works</span>
          </h2>
          <p class="max-w-2xl text-base leading-7 text-slate-300 md:text-lg pt-4">
            Una seleccion de proyectos donde priorice producto, claridad visual y decisiones tecnicas que pudieran sostener crecimiento real.
          </p>
        </div>
      </div>

      <div class="grid max-w-[72rem] gap-6">
        {projects.map((project, index) => (
          <article class="projects-item group/item relative">
            <span class="projects-item__dot" aria-hidden="true"></span>
            <span class="projects-item__connector" aria-hidden="true"></span>

            <div class="projects-card card-surface relative overflow-hidden rounded-[2rem] border border-white/6 bg-[linear-gradient(135deg,rgba(15,23,42,0.7)_0%,rgba(15,23,42,0.42)_45%,rgba(17,24,39,0.28)_100%)] p-3 shadow-[inset_0_1px_0_rgba(255,255,255,0.04)] transition-[border-color,box-shadow,background-color,transform] duration-[1000ms] ease-[cubic-bezier(0.22,1,0.36,1)] group-hover/item:border-[#ff6b2d]/70 group-hover/item:shadow-[inset_0_1px_0_rgba(255,255,255,0.05),0_0_0_1px_rgba(255,107,45,0.18),0_0_24px_rgba(255,107,45,0.14)] md:p-5">
              <div class={`relative grid items-center gap-6 min-[960px]:grid-cols-[minmax(0,0.96fr)_minmax(19rem,0.82fr)] min-[960px]:gap-7 ${index === 1 ? 'min-[960px]:grid-cols-[minmax(19rem,0.82fr)_minmax(0,0.96fr)]' : ''}`}>
                <div class={`min-w-0 ${index === 1 ? 'min-[960px]:order-2' : ''}`}>
                  <div class="overflow-hidden rounded-[1.2rem] border border-white/8 bg-[linear-gradient(180deg,rgba(17,24,39,0.96)_0%,rgba(15,23,42,0.96)_100%)] shadow-[inset_0_1px_0_rgba(255,255,255,0.04),0_18px_42px_rgba(2,6,23,0.4)] transition-[box-shadow,border-color,background-color,transform] duration-[1000ms] ease-[cubic-bezier(0.22,1,0.36,1)] group-hover/item:border-[#ff6b2d]/70 group-hover/item:shadow-[inset_0_1px_0_rgba(255,255,255,0.05),0_0_0_1px_rgba(255,107,45,0.18)]">
                    <img
                      src={project.image.src}
                      width={project.image.width}
                      height={project.image.height}
                      alt={`Captura del proyecto ${project.title}`}
                      class="block aspect-[16/10] h-full w-full rounded-[1.2rem] scale-88 object-cover object-top transition-transform duration-[1000ms] ease-[cubic-bezier(0.22,1,0.36,1)] group-hover/item:scale-92"
                      loading="lazy"
                      decoding="async"
                    />
                  </div>
                </div>

                <div class={`flex min-h-full min-w-0 flex-col justify-between gap-5 py-1 ${index === 1 ? 'min-[960px]:order-1' : ''}`}>
                  <div class="space-y-4">
                    <span class="inline-block text-3xl font-bold leading-none tracking-tight text-[#ff6b2d]/20 transition-colors duration-[1000ms] ease-[cubic-bezier(0.22,1,0.36,1)] group-hover/item:text-[#ff6b2d]/35 md:text-5xl">
                      {project.number}
                    </span>

                    <div class="space-y-3">
                      <p class="text-xs uppercase tracking-[0.28em] text-slate-400">{project.eyebrow}</p>
                      <h3 class="text-2xl font-semibold leading-tight text-white md:text-3xl">
                        {project.title}
                      </h3>
                      <p class="max-w-xl text-sm leading-6 text-slate-300 md:text-base">
                        {project.description}
                      </p>
                    </div>

                    <div class="flex flex-wrap gap-3">
                      {project.stack.map((item) => (
                        <span class="inline-flex items-center rounded-full border border-[#ff6b2d]/20 bg-[#ff6b2d]/8 px-4 py-2 text-sm font-semibold text-[#ffb08f] transition-all duration-[1000ms] ease-[cubic-bezier(0.22,1,0.36,1)] group-hover/item:border-[#ff6b2d]/35 group-hover/item:bg-[#ff6b2d]/12 group-hover/item:text-[#ffc2a9]">
                          {item}
                        </span>
                      ))}
                    </div>
                  </div>

                  <div class="flex items-center gap-3">
                    <a
                      class="project-action"
                      href={project.liveUrl}
                      target="_blank"
                      rel="noreferrer"
                      aria-label={`Abrir la web de ${project.title}`}
                      title="Ver sitio"
                    >
                      <svg viewBox="0 0 24 24" aria-hidden="true">
                        <path
                          fill="currentColor"
                          d="M3.75 5A2.25 2.25 0 0 1 6 2.75h12A2.25 2.25 0 0 1 20.25 5v10A2.25 2.25 0 0 1 18 17.25H6A2.25 2.25 0 0 1 3.75 15V5Zm1.5 0a.75.75 0 0 0 .75.75h12A.75.75 0 0 0 19.5 5 .75.75 0 0 0 18.75 4.25h-12A.75.75 0 0 0 5.25 5Zm0 2.19V15c0 .414.336.75.75.75h12a.75.75 0 0 0 .75-.75V7.19l-7.06 4.02a1.5 1.5 0 0 1-1.48 0L5.25 7.19Zm13.12-.94H5.63l5.37 3.06 7.37-4.2Z"
                        />
                        <path
                          fill="currentColor"
                          d="M8 19.25a.75.75 0 0 1 .75-.75h6.5a.75.75 0 0 1 0 1.5h-6.5a.75.75 0 0 1-.75-.75Z"
                        />
                      </svg>
                    </a>

                    {project.githubUrl && (
                      <a
                        class="project-action"
                        href={project.githubUrl}
                        target="_blank"
                        rel="noreferrer"
                        aria-label={`Abrir el codigo fuente de ${project.title}`}
                        title="Ver codigo"
                      >
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                          <path
                            fill="currentColor"
                            d="M12 1.25a10.75 10.75 0 0 0-3.4 20.95c.54.1.73-.23.73-.52v-1.85c-2.98.65-3.6-1.28-3.6-1.28-.49-1.23-1.18-1.56-1.18-1.56-.97-.66.08-.65.08-.65 1.07.08 1.64 1.1 1.64 1.1.95 1.63 2.49 1.16 3.1.89.1-.69.37-1.16.67-1.42-2.38-.27-4.88-1.19-4.88-5.29 0-1.17.42-2.13 1.1-2.88-.11-.27-.48-1.36.11-2.84 0 0 .9-.29 2.95 1.1a10.2 10.2 0 0 1 5.38 0c2.05-1.39 2.94-1.1 2.94-1.1.6 1.48.23 2.57.11 2.84.69.75 1.1 1.71 1.1 2.88 0 4.11-2.5 5.01-4.88 5.28.38.33.72.98.72 1.98v2.94c0 .29.19.62.74.52A10.75 10.75 0 0 0 12 1.25Z"
                          />
                        </svg>
                      </a>
                    )}
                  </div>
                </div>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .projects-shell {
    position: relative;
    padding-left: clamp(1.75rem, 4vw, 4.5rem);
  }

  .projects-rail {
    position: absolute;
    inset-block: 0.5rem;
    left: 0;
    width: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .projects-rail__line {
    position: absolute;
    inset-block: 0;
    left: 50%;
    width: 1px;
    background: linear-gradient(180deg, rgba(255, 107, 45, 0.12) 0%, rgba(255, 107, 45, 0.55) 22%, rgba(255, 107, 45, 0.12) 100%);
    transform: translateX(-50%);
  }

  .projects-rail__node {
    position: absolute;
    left: 50%;
    border-radius: 999px;
    transform: translateX(-50%);
  }

  .projects-rail__node--top {
    top: 0;
    width: 0.9rem;
    height: 0.9rem;
    background: #ff6b2d;
    box-shadow: 0 0 0 4px rgba(255, 107, 45, 0.08), 0 0 18px rgba(255, 107, 45, 0.42);
  }

  .projects-item__dot {
    position: absolute;
    top: 3rem;
    left: calc(clamp(1.75rem, 4vw, 4.5rem) * -1);
    width: 1.15rem;
    height: 1.15rem;
    border-radius: 999px;
    border: 2px solid rgba(255, 107, 45, 0.95);
    background: rgba(10, 14, 26, 0.96);
    box-shadow: 0 0 0 0.32rem rgba(255, 107, 45, 0.08), 0 0 1.2rem rgba(255, 107, 45, 0.18);
    transform: translateX(calc(-50% + 0.75rem));
    z-index: 3;
    transition:
      border-color 1000ms cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 1000ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 1000ms cubic-bezier(0.22, 1, 0.36, 1),
      background 1000ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .projects-item__connector {
    position: absolute;
    top: 3.52rem;
    left: calc(clamp(1.75rem, 4vw, 4.5rem) * -1 + 0.75rem);
    width: clamp(1rem, 1.6vw, 1.5rem);
    height: 1px;
    background: linear-gradient(90deg, rgba(255, 107, 45, 0.65) 0%, rgba(255, 107, 45, 0) 100%);
    z-index: 2;
    pointer-events: none;
  }

  .projects-item:hover .projects-item__dot,
  .projects-item:focus-within .projects-item__dot {
    border-color: rgba(255, 149, 112, 1);
    background: #120d0a;
    box-shadow: 0 0 0 0.38rem rgba(255, 107, 45, 0.12), 0 0 1.6rem rgba(255, 107, 45, 0.28);
    transform: translateX(calc(-50% + 0.75rem)) scale(1.06);
  }

  .project-action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    border-radius: 999px;
    border: 1px solid rgb(56 65 82 / 45%);
    background: rgb(56 65 82 / 18%);
    color: #cbd5e1;
    text-decoration: none;
    transition:
      transform 1000ms cubic-bezier(0.22, 1, 0.36, 1),
      border-color 1000ms cubic-bezier(0.22, 1, 0.36, 1),
      background-color 1000ms cubic-bezier(0.22, 1, 0.36, 1),
      color 1000ms cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 1000ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .project-action:hover,
  .project-action:focus-visible {
    transform: translateY(-0.1rem);
    border-color: rgb(56 65 82 / 75%);
    background: rgb(56 65 82 / 28%);
    color: #e2e8f0;
    box-shadow: 0 0 0 1px rgb(56 65 82 / 18%), 0 0 24px rgb(56 65 82 / 18%);
  }

  .project-action svg {
    width: 1.25rem;
    height: 1.25rem;
  }

  @media (max-width: 959px) {
    .projects-shell {
      padding-left: 1.25rem;
      padding-right: 1.25rem;
    }

    .projects-rail,
    .projects-item__dot,
    .projects-item__connector {
      display: none;
    }
  }
</style>
