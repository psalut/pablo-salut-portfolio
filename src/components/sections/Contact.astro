---
import profileImage from '../../assets/images/profile.webp';

const contactLinks = {
  email: 'mailto:pablosalut03@gmail.com',
  linkedin: 'https://www.linkedin.com/in/pablo-salut-arg/',
  github: 'https://github.com/psalut',
  whatsapp: 'https://wa.me/5493472526823',
} as const;
---

<section id="contact" class="section-spacing">
  <div class="section-container">
    <div class="space-y-4">
      <p class="text-sm uppercase tracking-[0.3em] text-slate-400">Contact</p>
      <article class="contact-card card-surface overflow-hidden rounded-[2rem] p-5 md:p-8">
        <div class="contact-card__glow" aria-hidden="true"></div>

        <div class="contact-card__inner">
          <div class="contact-identity">
            <div class="contact-avatar" aria-hidden="true">
              <img
                src={profileImage.src}
                width={profileImage.width}
                height={profileImage.height}
                alt=""
                loading="lazy"
                decoding="async"
              />
            </div>

            <div class="space-y-1">
              <p class="contact-identity__name">Pablo Salut</p>
              <p class="contact-identity__role">Fullstack Developer · Frontend focused</p>
            </div>
          </div>

          <div class="contact-copy">

            <h2 class="m-0 text-4xl font-semibold leading-[0.95] tracking-tight text-white md:text-5xl lg:text-5xl">
              ¿Trabajamos <span class="contact-copy__accent">juntos?</span>
            </h2>

            <p class="mx-auto max-w-3xl text-base leading-7 text-slate-300 md:text-lg md:leading-7">
              Estoy disponible para proyectos freelance, colaboraciones o nuevas oportunidades.
              Si estás construyendo algo, me encantaría escuchar tu idea.
            </p>
          </div>

          <div class="contact-actions">
            <a class="contact-button contact-button--primary" href={contactLinks.email}>
              <span class="contact-button__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24">
                  <path fill="currentColor" d="M3.75 6A2.25 2.25 0 0 1 6 3.75h12A2.25 2.25 0 0 1 20.25 6v12A2.25 2.25 0 0 1 18 20.25H6A2.25 2.25 0 0 1 3.75 18V6Zm2.2-.75a.75.75 0 0 0-.41 1.38l5.84 3.89a1.1 1.1 0 0 0 1.22 0l5.84-3.89a.75.75 0 0 0-.42-1.38H5.95Zm12.8 3.18-5.32 3.55a2.6 2.6 0 0 1-2.87 0L5.25 8.43V18c0 .41.34.75.75.75h12c.41 0 .75-.34.75-.75V8.43Z"/>
                </svg>
              </span>
              <span>Email</span>
            </a>

            <a class="contact-button contact-button--linkedin" href={contactLinks.linkedin} target="_blank" rel="noreferrer">
              <span class="contact-button__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24">
                  <path fill="currentColor" d="M6.75 8.25a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3Zm-1.2 1.5h2.4v8.7h-2.4v-8.7Zm4.2 0h2.3v1.24h.03c.32-.6 1.1-1.47 2.27-1.47 2.42 0 2.87 1.6 2.87 3.67v5.26h-2.4v-4.67c0-1.12-.02-2.56-1.56-2.56-1.56 0-1.8 1.22-1.8 2.48v4.75h-2.4v-8.7Z"/>
                  <path fill="currentColor" d="M4.5 3.75A1.75 1.75 0 0 0 2.75 5.5v13A1.75 1.75 0 0 0 4.5 20.25h15A1.75 1.75 0 0 0 21.25 18.5v-13A1.75 1.75 0 0 0 19.5 3.75h-15Zm0 1.5h15c.14 0 .25.11.25.25v13a.25.25 0 0 1-.25.25h-15a.25.25 0 0 1-.25-.25v-13c0-.14.11-.25.25-.25Z"/>
                </svg>
              </span>
              <span>LinkedIn</span>
            </a>

            <a class="contact-button contact-button--github" href={contactLinks.github} target="_blank" rel="noreferrer">
              <span class="contact-button__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24">
                  <path fill="currentColor" d="M12 1.75a10.25 10.25 0 0 0-3.24 19.98c.51.1.69-.22.69-.5v-1.76c-2.84.62-3.43-1.2-3.43-1.2-.46-1.18-1.13-1.49-1.13-1.49-.92-.63.07-.62.07-.62 1.02.07 1.56 1.04 1.56 1.04.9 1.55 2.36 1.1 2.94.84.1-.66.35-1.11.64-1.37-2.27-.26-4.66-1.13-4.66-5.05 0-1.12.4-2.04 1.05-2.76-.1-.26-.46-1.3.1-2.72 0 0 .87-.28 2.83 1.05a9.74 9.74 0 0 1 5.16 0c1.96-1.33 2.83-1.05 2.83-1.05.56 1.42.2 2.46.1 2.72.65.72 1.05 1.64 1.05 2.76 0 3.93-2.4 4.79-4.68 5.04.37.31.7.92.7 1.86v2.76c0 .28.18.6.7.5A10.25 10.25 0 0 0 12 1.75Z"/>
                </svg>
              </span>
              <span>GitHub</span>
            </a>

            <a class="contact-button contact-button--whatsapp" href={contactLinks.whatsapp} target="_blank" rel="noreferrer">
              <span class="contact-button__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24">
                  <path fill="currentColor" d="M12 2.25A9.73 9.73 0 0 0 3.68 17.1L2.25 21.75l4.77-1.37A9.75 9.75 0 1 0 12 2.25Zm0 1.5a8.25 8.25 0 0 1 7.08 12.47l-.18.28.85 2.78-2.85-.82-.28.17A8.25 8.25 0 1 1 12 3.75Zm-2.2 4.12c-.2 0-.42.01-.6.1-.16.08-.39.26-.59.48-.2.22-.76.75-.76 1.83 0 1.08.78 2.12.9 2.27.11.15 1.5 2.4 3.75 3.27 1.87.72 2.25.57 2.65.54.41-.03 1.31-.54 1.5-1.07.19-.53.19-.99.13-1.08-.05-.08-.2-.14-.41-.25-.22-.1-1.31-.64-1.51-.72-.2-.07-.35-.1-.49.1-.15.2-.56.72-.69.87-.13.15-.25.17-.47.06-.22-.1-.9-.33-1.72-1.07-.64-.56-1.08-1.25-1.2-1.46-.12-.2-.01-.32.08-.42.08-.08.2-.22.3-.33.1-.12.13-.2.2-.34.06-.13.03-.25-.02-.35-.05-.1-.46-1.1-.64-1.5-.17-.4-.34-.34-.47-.35Z"/>
                </svg>
              </span>
              <span>WhatsApp</span>
            </a>
          </div>
        </div>
      </article>
    </div>
  </div>
</section>

<style>
  .contact-card {
    position: relative;
    background:
      radial-gradient(circle at top left, rgba(255, 107, 45, 0.18), transparent 30%),
      linear-gradient(135deg, rgba(15, 23, 42, 0.92) 0%, rgba(15, 23, 42, 0.78) 42%, rgba(17, 24, 39, 0.92) 100%);
    border-color: rgba(255, 255, 255, 0.08);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.04),
      0 24px 80px rgba(2, 6, 23, 0.28);
  }

  .contact-card__glow {
    position: absolute;
    inset: auto auto -8rem -4rem;
    width: 18rem;
    height: 18rem;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(255, 107, 45, 0.18) 0%, rgba(255, 107, 45, 0) 72%);
    pointer-events: none;
  }

  .contact-card__inner {
    position: relative;
    display: grid;
    gap: 2rem;
    justify-items: center;
    text-align: center;
  }

  .contact-identity {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    width: 100%;
  }

  .contact-avatar {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    width: 8rem;
    height: 8rem;
    border-radius: 999px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.14), rgba(255, 255, 255, 0.04)),
      rgba(15, 23, 42, 0.85);
    border: 1px solid rgba(255, 255, 255, 0.12);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.08),
      0 16px 36px rgba(2, 6, 23, 0.24);
  }

  .contact-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .contact-identity__name {
    margin: 0;
    font-size: 1.35rem;
    font-weight: 600;
    color: #fff;
    text-align: left;
  }

  .contact-identity__role {
    margin: 0;
    font-size: 0.98rem;
    color: #94a3b8;
    text-align: left;
  }

  .contact-copy {
    display: grid;
    gap: 1.5rem;
    justify-items: center;
  }

  .contact-copy__accent {
    display: block;
    color: #ff6b2d;
  }

  .contact-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
  }

  .contact-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.8rem;
    min-height: 2rem;
    padding: 0.65rem 1.5rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.03)),
      rgba(15, 23, 42, 0.78);
    color: #e2e8f0;
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.05),
      0 14px 34px rgba(2, 6, 23, 0.22);
    transition:
      transform 220ms ease,
      border-color 220ms ease,
      background 220ms ease,
      color 220ms ease,
      box-shadow 220ms ease;
  }

  .contact-button:hover,
  .contact-button:focus-visible {
    transform: translateY(-2px);
    border-color: rgba(255, 255, 255, 0.16);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.11), rgba(255, 255, 255, 0.04)),
      rgba(15, 23, 42, 0.88);
    color: #fff;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.06),
      0 18px 36px rgba(2, 6, 23, 0.28);
  }

  .contact-button:focus-visible {
    outline: 2px solid rgba(255, 255, 255, 0.35);
    outline-offset: 0.2rem;
  }

  .contact-button__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.35rem;
    height: 1.35rem;
    flex: 0 0 auto;
  }

  .contact-button__icon svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .contact-button--primary {
    border-color: rgba(255, 107, 45, 0.38);
    background:
      linear-gradient(180deg, rgba(255, 149, 112, 0.18), rgba(255, 107, 45, 0.14)),
      rgba(255, 107, 45, 0.15);
    color: #fff7f2;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.08),
      0 18px 36px rgba(255, 107, 45, 0.2);
  }

  .contact-button--primary:hover,
  .contact-button--primary:focus-visible {
    border-color: rgba(255, 149, 112, 0.48);
    background:
      linear-gradient(180deg, rgba(255, 149, 112, 0.24), rgba(255, 107, 45, 0.18)),
      rgba(255, 107, 45, 0.2);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.08),
      0 22px 40px rgba(255, 107, 45, 0.22);
  }

  .contact-button--whatsapp:hover,
  .contact-button--whatsapp:focus-visible {
    border-color: rgba(34, 197, 94, 0.36);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.06),
      0 18px 36px rgba(34, 197, 94, 0.12);
  }

  .contact-button--linkedin:hover,
  .contact-button--linkedin:focus-visible {
    border-color: rgba(96, 165, 250, 0.36);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.06),
      0 18px 36px rgba(59, 130, 246, 0.14);
  }

  .contact-button--github:hover,
  .contact-button--github:focus-visible {
    border-color: rgba(255, 255, 255, 0.24);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.06),
      0 18px 36px rgba(255, 255, 255, 0.12);
  }

  @media (max-width: 720px) {
    .contact-identity {
      flex-direction: column;
      align-items: center;
    }

    .contact-identity__name,
    .contact-identity__role {
      text-align: center;
    }

    .contact-actions {
      width: 100%;
    }

    .contact-button {
      width: min(100%, 12rem);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .contact-button {
      transition: border-color 220ms ease, background 220ms ease, color 220ms ease, box-shadow 220ms ease;
    }

    .contact-button:hover,
    .contact-button:focus-visible {
      transform: none;
    }
  }
</style>
