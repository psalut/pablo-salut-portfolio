---
const mockWork = [
  {
    period: '2024 - Present',
    role: 'Frontend Developer',
    company: 'Current Company',
    description:
      'Working on modern web interfaces, reusable UI patterns and product-oriented frontend development.',
  },
  {
    period: '2023 - 2024',
    role: 'Frontend / Full Stack Developer',
    company: 'Previous Company',
    description:
      'Built and maintained web applications with focus on Angular, APIs and technical scalability.',
  },
  {
    period: '2022 - 2023',
    role: 'Junior Developer',
    company: 'Earlier Work',
    description:
      'Started professional work delivering features, fixing issues and learning production workflows.',
  },
];
---

<section id="work" class="section-spacing">
  <div class="section-container space-y-10">
    <div class="space-y-4">
      <p class="text-sm uppercase tracking-[0.3em] text-slate-400">Work</p>
      <h2 class="text-3xl font-semibold md:text-5xl">Work</h2>
      <p class="max-w-2xl text-base leading-7 text-slate-300">
        This section will replace the original “Latest posts” area with a more relevant
        professional history block.
      </p>
    </div>

    <div class="grid gap-6">
      {mockWork.map((item) => (
        <article class="card-surface rounded-3xl p-6 md:p-8">
          <div class="grid gap-4 md:grid-cols-[180px_1fr]">
            <div class="text-sm font-medium text-slate-400">{item.period}</div>

            <div class="space-y-3">
              <h3 class="text-2xl font-semibold">
                {item.role} · <span class="text-slate-400">{item.company}</span>
              </h3>

              <p class="max-w-2xl text-base leading-7 text-slate-300">
                {item.description}
              </p>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
