---
const skills = [
  'Frontend Architecture',
  'Responsive Design',
  'API Design',
  'Design Systems',
  'Component Architecture',
  'Performance Optimization',
];

const toolCategories = [
  { category: 'Frontend', items: ['Angular','React','Next.js','Vite','Nx','Astro','TypeScript','Tailwind','Lit','Web Components','Framer Motion'] },
  { category: 'Backend', items: ['Node.js','NestJS','Express','Prisma'] },
  { category: 'Database', items: ['PostgreSQL','MongoDB','Firebase'] },
  { category: 'Tools', items: ['Git','Vercel','Docker','Jest','Playwright','Git','GitHub Actions','CI/CD'] },
 ] as const;

type ToolName = (typeof toolCategories)[number]['items'][number];
type ToolCategory = (typeof toolCategories)[number];

const createMonogramIcon = (label: string, background: string, text = '#ffffff'): string => `
  <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
    <rect x="2" y="2" width="20" height="20" rx="6" fill="${background}" />
    <text x="12" y="14.2" text-anchor="middle" font-size="8.5" font-weight="700" font-family="Segoe UI, Arial, sans-serif" fill="${text}">
      ${label}
    </text>
  </svg>
`;

