const getToolIcon = (item: ToolName): string =>
  toolIcons[item] ?? createMonogramIcon(item.slice(0, 2).toUpperCase(), '#475569');
---

<section id="skills" class="section-spacing">
  <div class="section-container space-y-8 md:space-y-10">
    <div class="space-y-4">
      <p class="text-sm uppercase tracking-[0.3em] text-slate-400">Skills</p>
      <h2 class="text-3xl font-semibold md:text-5xl">
        Skills <span class="text-[#ff6b2d]">&</span> tools
      </h2>
    </div>

    <div class="space-y-6">
      <div class="grid gap-x-6 gap-y-3 md:grid-cols-2">
        {skills.map((item) => (
          <div class="flex items-center gap-4">
            <span class="skills-dot" aria-hidden="true"></span>
            <span class="text-base font-medium text-slate-200 md:text-lg">{item}</span>
          </div>
        ))}
      </div>
    </div>

    <div class="skills-divider" aria-hidden="true"></div>

    <div class="space-y-6">
      <div class="space-y-6">
        {toolCategories.map((group: ToolCategory) => (
          <div class="grid gap-4 border-b border-white/6 pb-6 md:grid-cols-[minmax(0,12rem)_minmax(0,1fr)] md:gap-6 last:border-b-0 last:pb-0">
            <div>
              <h4 class="m-0 text-[clamp(1.35rem,2vw,1.9rem)] font-semibold leading-[1.1] text-slate-200">
                {group.category}
              </h4>
            </div>

            <div class="flex flex-wrap gap-3.5">
              {group.items.map((item: ToolName) => (
                <span class="inline-flex min-h-12 items-center gap-2.5 rounded-full border border-white/10 bg-[linear-gradient(180deg,rgba(255,255,255,0.08),rgba(255,255,255,0.03)),rgba(15,23,42,0.54)] px-4 py-3 text-[0.88rem] font-normal tracking-[-0.01em] text-slate-200 shadow-[inset_0_1px_0_rgba(255,255,255,0.05),0_14px_30px_rgba(2,6,23,0.2)] transition-[transform,border-color,background,box-shadow] duration-200 hover:-translate-y-px hover:border-[#ff6b2d]/30 hover:bg-[linear-gradient(180deg,rgba(255,255,255,0.1),rgba(255,255,255,0.04)),rgba(15,23,42,0.62)] hover:shadow-[inset_0_1px_0_rgba(255,255,255,0.05),0_16px_32px_rgba(2,6,23,0.24),0_0_0_1px_rgba(255,107,45,0.12)]">
                  <span class="tool-pill__icon inline-flex h-5 w-5 shrink-0 items-center justify-center" aria-hidden="true">
                    <Fragment set:html={getToolIcon(item)} />
                  </span>
                  <span>{item}</span>
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .skills-divider {
    height: 1px;
    width: 100%;
    background: linear-gradient(90deg, rgba(255, 107, 45, 0) 0%, rgba(255, 107, 45, 0.3) 20%, rgba(255, 255, 255, 0.08) 50%, rgba(255, 107, 45, 0.3) 80%, rgba(255, 107, 45, 0) 100%);
  }

  .skills-dot {
    width: 0.62rem;
    height: 0.62rem;
    border-radius: 999px;
    flex: 0 0 auto;
    background: #ff6b2d;
    box-shadow: 0 0 0 0.34rem rgba(255, 107, 45, 0.12), 0 0 1rem rgba(255, 107, 45, 0.22);
  }

  .tool-pill__icon :global(svg) {
    width: 100%;
    height: 100%;
    display: block;
  }
</style>
